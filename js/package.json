{
  "name": "@apex-trace/js",
  "version": "1.0.0",
  "description": "Distributed tracing library for Apex ecosystem - React/TypeScript applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
